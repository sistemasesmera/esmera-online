---
import Container from "./ui/Container.astro";
---

<div
  id="cookie-notice"
  data-cookie-notice
  class="fixed inset-x-0 bottom-0 z-[90] translate-y-full border-t border-white/10 bg-ink-950 text-ink-300 shadow-[0_-8px_30px_-10px_rgba(0,0,0,0.3)] transition-transform duration-300"
>
  <Container class="flex flex-col items-center gap-4 py-5 sm:flex-row sm:justify-between">
    <p class="text-sm leading-relaxed text-ink-300">
      Este sitio no utiliza cookies de analítica ni de marketing.
      <a href="/cookies" class="underline hover:text-white">Más información</a>.
    </p>
    <button
      type="button"
      data-cookie-notice-dismiss
      class="w-full shrink-0 rounded-lg bg-brand-600 px-5 py-2.5 font-display text-sm font-semibold text-white transition-colors duration-150 hover:bg-brand-700 sm:w-auto"
    >
      Entendido
    </button>
  </Container>
</div>

<script>
  const STORAGE_KEY = "esmera-cookie-notice-dismissed";

  function initCookieNotice() {
    const notice = document.querySelector<HTMLElement>("[data-cookie-notice]");
    if (!notice || notice.dataset.bound) return;
    notice.dataset.bound = "true";

    const setShift = (px: number) => {
      document.documentElement.style.setProperty("--cookie-notice-shift", `-${px}px`);
    };

    if (!localStorage.getItem(STORAGE_KEY)) {
      requestAnimationFrame(() => {
        notice.classList.remove("translate-y-full");
        setShift(notice.offsetHeight);
      });
    }

    notice.querySelector("[data-cookie-notice-dismiss]")?.addEventListener("click", () => {
      localStorage.setItem(STORAGE_KEY, "true");
      notice.classList.add("translate-y-full");
      setShift(0);
    });
  }

  document.addEventListener("astro:page-load", initCookieNotice);
</script>
