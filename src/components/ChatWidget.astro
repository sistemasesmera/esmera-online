---
// Scripted lead-capture widget — not a real AI assistant yet. The conversation
// is a fixed decision tree; "free text" replies fall back to the same quick
// replies. Swap in a real assistant later without changing the surrounding UI.
import Icon from "./Icon.astro";
---

<div class="fixed bottom-5 right-5 z-50 flex flex-col items-end gap-3 sm:bottom-6 sm:right-6">
  <div
    id="chat-panel"
    class="grid w-[min(22rem,calc(100vw-2.5rem))] origin-bottom-right grid-rows-[0fr] overflow-hidden opacity-0 transition-[grid-template-rows,opacity] duration-300 ease-out"
  >
    <div class="overflow-hidden rounded-3xl border border-ink-100 bg-white shadow-2xl shadow-ink-900/15">
      <div class="relative flex items-center justify-between overflow-hidden bg-ink-950 px-5 py-4 text-white">
        <div class="absolute inset-0 bg-grain"></div>
        <div class="relative flex items-center gap-3">
          <span class="flex h-9 w-9 items-center justify-center rounded-full bg-brand-500/20 text-brand-300">
            <Icon name="bot" class="h-5 w-5" />
          </span>
          <span>
            <span class="block font-display text-sm font-semibold">Asistente Esmera Online</span>
            <span class="flex items-center gap-1.5 font-mono text-xs text-ink-300">
              <span class="h-1.5 w-1.5 rounded-full bg-brand-400"></span>
              Disponible ahora
            </span>
          </span>
        </div>
        <button
          id="chat-close"
          type="button"
          aria-label="Cerrar chat"
          class="relative rounded-full p-1.5 text-ink-300 transition-colors hover:bg-white/10 hover:text-white"
        >
          <Icon name="close" class="h-4 w-4" />
        </button>
      </div>

      <div id="chat-messages" class="flex max-h-96 flex-col gap-3 overflow-y-auto p-4" aria-live="polite"></div>

      <div id="chat-quick-replies" class="flex flex-wrap gap-2 px-4 pb-3"></div>

      <form id="chat-form" class="flex items-center gap-2 border-t border-ink-100 p-3">
        <input
          id="chat-input"
          type="text"
          autocomplete="off"
          placeholder="Escribe tu mensaje..."
          class="flex-1 rounded-full border border-ink-200 px-4 py-2 text-sm text-ink-900 outline-none transition-colors focus:border-brand-500 focus:ring-2 focus:ring-brand-100"
        />
        <button
          type="submit"
          aria-label="Enviar"
          class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-brand-600 text-white transition-colors hover:bg-brand-700"
        >
          <Icon name="send" class="h-4 w-4" />
        </button>
      </form>
    </div>
  </div>

  <button
    id="chat-toggle"
    type="button"
    aria-label="Abrir chat"
    aria-expanded="false"
    class="relative flex h-14 w-14 items-center justify-center rounded-full bg-brand-600 text-white shadow-xl shadow-brand-600/30 transition-transform duration-200 hover:scale-105 active:scale-95"
  >
    <span class="absolute inset-0 rounded-full bg-brand-500/60 motion-safe:animate-ping"></span>
    <Icon name="chat" class="relative h-6 w-6" />
  </button>
</div>

<script>
  import { submitLead } from "../lib/leads";

  type Step = "greeting" | "category" | "contact" | "done";

  interface BotState {
    step: Step;
    category?: string;
  }

  const CATEGORY_INFO: Record<string, string> = {
    "Inteligencia Artificial":
      "Nuestro curso de IA te enseña a aplicar la inteligencia artificial en tu trabajo diario, sin necesidad de perfil técnico previo.",
    Ciberseguridad:
      "Formación desde cero en ciberseguridad: redes, vulnerabilidades y respuesta a incidentes, con proyecto final incluido.",
    "Marketing Digital":
      "Aprende a diseñar y ejecutar estrategias de marketing digital reales, con tutor asignado y tutorías semanales.",
  };

  function initChatWidget() {
    const toggle = document.querySelector<HTMLButtonElement>("#chat-toggle");
    const closeBtn = document.querySelector<HTMLButtonElement>("#chat-close");
    const panel = document.querySelector<HTMLDivElement>("#chat-panel");
    const messages = document.querySelector<HTMLDivElement>("#chat-messages");
    const quickReplies = document.querySelector<HTMLDivElement>("#chat-quick-replies");
    const form = document.querySelector<HTMLFormElement>("#chat-form");
    const input = document.querySelector<HTMLInputElement>("#chat-input");

    if (!toggle || !closeBtn || !panel || !messages || !quickReplies || !form || !input) return;
    if (toggle.dataset.bound) return;
    toggle.dataset.bound = "true";

    const state: BotState = { step: "greeting" };

    function addMessage(text: string, from: "bot" | "user") {
      const bubble = document.createElement("div");
      bubble.className =
        from === "bot"
          ? "max-w-[85%] self-start rounded-2xl rounded-tl-sm bg-ink-50 px-4 py-2.5 text-sm text-ink-700"
          : "max-w-[85%] self-end rounded-2xl rounded-tr-sm bg-brand-600 px-4 py-2.5 text-sm text-white";
      bubble.textContent = text;
      messages?.appendChild(bubble);
      if (messages) messages.scrollTop = messages.scrollHeight;
    }

    function setQuickReplies(options: string[]) {
      if (!quickReplies) return;
      quickReplies.innerHTML = "";
      for (const option of options) {
        const btn = document.createElement("button");
        btn.type = "button";
        btn.textContent = option;
        btn.className =
          "rounded-full border border-brand-200 bg-brand-50 px-3.5 py-1.5 text-xs font-medium text-brand-700 transition-colors hover:bg-brand-100";
        btn.addEventListener("click", () => handleUserChoice(option));
        quickReplies.appendChild(btn);
      }
    }

    function showGreeting() {
      addMessage("¡Hola! 👋 Soy el asistente de Esmera Online. ¿En qué te gustaría formarte?", "bot");
      setQuickReplies(["Inteligencia Artificial", "Ciberseguridad", "Marketing Digital", "Aún no lo sé"]);
    }

    function askForContact() {
      state.step = "contact";
      addMessage("Genial, déjame tu email y un asesor te contactará para darte todos los detalles.", "bot");
      setQuickReplies([]);
      input?.setAttribute("type", "email");
      input?.setAttribute("placeholder", "tu@email.com");
    }

    function handleUserChoice(option: string) {
      addMessage(option, "user");

      if (option in CATEGORY_INFO) {
        state.category = option;
        state.step = "category";
        addMessage(CATEGORY_INFO[option], "bot");
        setQuickReplies(["Quiero que me contacten", "Aún no lo sé"]);
        return;
      }

      if (option === "Quiero que me contacten" || option === "Aún no lo sé") {
        askForContact();
        return;
      }
    }

    form.addEventListener("submit", (event) => {
      event.preventDefault();
      const value = input.value.trim();
      if (!value) return;

      if (state.step === "contact") {
        addMessage(value, "user");
        submitLead({ name: "Visitante del chat", email: value, phone: "", courseOfInterest: state.category });
        addMessage("¡Listo! Hemos abierto tu cliente de correo para enviar tu solicitud. Un asesor te contactará pronto.", "bot");
        state.step = "done";
        input.value = "";
        input.setAttribute("type", "text");
        input.setAttribute("placeholder", "Escribe tu mensaje...");
        return;
      }

      addMessage(value, "user");
      input.value = "";
      addMessage("Gracias por tu mensaje. Para ayudarte mejor, cuéntame qué te interesa:", "bot");
      setQuickReplies(["Inteligencia Artificial", "Ciberseguridad", "Marketing Digital", "Quiero que me contacten"]);
    });

    function openPanel() {
      panel?.classList.replace("grid-rows-[0fr]", "grid-rows-[1fr]");
      panel?.classList.replace("opacity-0", "opacity-100");
      toggle?.setAttribute("aria-expanded", "true");
      if (messages && messages.childElementCount === 0) showGreeting();
    }

    function closePanel() {
      panel?.classList.replace("grid-rows-[1fr]", "grid-rows-[0fr]");
      panel?.classList.replace("opacity-100", "opacity-0");
      toggle?.setAttribute("aria-expanded", "false");
    }

    toggle.addEventListener("click", () => {
      const isOpen = toggle.getAttribute("aria-expanded") === "true";
      isOpen ? closePanel() : openPanel();
    });

    closeBtn.addEventListener("click", closePanel);
  }

  document.addEventListener("astro:page-load", initChatWidget);
</script>
