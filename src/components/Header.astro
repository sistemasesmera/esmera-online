---
import Logo from "./Logo.astro";
import Button from "./ui/Button.astro";
import Container from "./ui/Container.astro";
import Icon from "./Icon.astro";
import { getCollection } from "astro:content";

const categories = (await getCollection("categories")).sort((a, b) => a.data.order - b.data.order);

const navLinks = [
  { href: "/cursos", label: "Cursos" },
  { href: "/certificados-de-profesionalidad", label: "Certificados" },
  { href: "/blog", label: "Blog" },
  { href: "/contacto", label: "Contacto" },
];

const currentPath = Astro.url.pathname;
const isActive = (href: string) => currentPath === href || currentPath.startsWith(`${href}/`);
---

<header
  id="site-header"
  class="sticky top-0 z-50 border-b border-ink-100/70 bg-white/85 backdrop-blur-md transition-shadow duration-300"
>
  <Container class="flex h-18 items-center justify-between py-3">
    <Logo imageOnly />

    <nav class="hidden items-center gap-7 lg:flex">
      <div class="group relative">
        <button class="relative flex cursor-pointer items-center gap-1 text-sm font-medium text-ink-700 transition-colors duration-200 after:absolute after:-bottom-1.5 after:left-0 after:h-px after:w-0 after:bg-brand-600 after:transition-all after:duration-300 hover:text-brand-700 group-hover:after:w-[calc(100%-0.85rem)]">
          Categorías
          <svg width="10" height="6" viewBox="0 0 10 6" fill="none" class="text-ink-400 transition-transform duration-200 group-hover:rotate-180">
            <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
          </svg>
        </button>
        <div
          class="invisible absolute left-1/2 top-full grid w-80 -translate-x-1/2 translate-y-1 grid-cols-1 gap-0.5 rounded-2xl border border-ink-100 bg-white p-2 opacity-0 shadow-xl shadow-ink-900/10 transition-all duration-200 ease-out group-hover:visible group-hover:translate-y-0 group-hover:opacity-100"
        >
          {
            categories.map((category) => (
              <a
                href={`/categorias/${category.id}`}
                class="group/item flex items-center gap-3 rounded-xl px-3 py-2.5 text-sm font-medium text-ink-700 transition-colors duration-150 hover:bg-brand-50 hover:text-brand-700"
              >
                <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-brand-50 text-brand-600 transition-colors duration-150 group-hover/item:bg-white">
                  <Icon name={(category.data.icon as "sparkles" | "shield" | "megaphone" | "award" | "users" | "briefcase" | "compass" | "chart" | "target" | "clock" | "bot" | "calendar" | "brush") ?? "sparkles"} class="h-4 w-4" />
                </span>
                <span>
                  <span class="block">{category.data.name}</span>
                  <span class="block text-xs font-normal text-ink-400">{category.data.description}</span>
                </span>
              </a>
            ))
          }
          <a
            href="/cursos"
            class="mt-1 flex items-center justify-between rounded-xl border-t border-ink-100 px-3 py-2.5 text-sm font-semibold text-brand-700 transition-colors duration-150 hover:bg-brand-50"
          >
            Ver todos los cursos
            <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>

      {
        navLinks.map((link) => (
          <a
            href={link.href}
            aria-current={isActive(link.href) ? "page" : undefined}
            class:list={[
              "relative text-sm font-medium transition-colors duration-200 after:absolute after:-bottom-1.5 after:left-0 after:h-px after:bg-brand-600 after:transition-all after:duration-300 hover:text-brand-700 hover:after:w-full",
              isActive(link.href) ? "text-brand-700 after:w-full" : "text-ink-700 after:w-0",
            ]}
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="hidden items-center gap-5 lg:flex">
      <span class="h-6 w-px bg-ink-100" aria-hidden="true"></span>
      <Button href="javascript:void(0)" variant="primary" data-lead-modal-trigger>Habla con un asesor</Button>
    </div>

    <button
      id="mobile-menu-button"
      class="relative inline-flex h-9 w-9 cursor-pointer items-center justify-center rounded-full text-ink-700 lg:hidden"
      aria-label="Abrir menú"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span class="sr-only">Abrir menú</span>
      <span
        class="absolute left-1/2 top-1/2 h-[1.5px] w-5 -translate-x-1/2 rounded-full bg-current transition-all duration-300"
        style="transform: translate(-50%, -6px) rotate(0deg);"
        data-menu-bar="top"
      ></span>
      <span
        class="absolute left-1/2 top-1/2 h-[1.5px] w-5 -translate-x-1/2 -translate-y-1/2 rounded-full bg-current transition-all duration-300"
        data-menu-bar="middle"
      ></span>
      <span
        class="absolute left-1/2 top-1/2 h-[1.5px] w-5 -translate-x-1/2 rounded-full bg-current transition-all duration-300"
        style="transform: translate(-50%, 5px) rotate(0deg);"
        data-menu-bar="bottom"
      ></span>
    </button>
  </Container>

  <div
    id="mobile-menu"
    class="grid grid-rows-[0fr] overflow-hidden border-t border-transparent bg-white opacity-0 transition-[grid-template-rows,opacity] duration-300 ease-out lg:hidden"
  >
    <div class="overflow-hidden">
      <Container class="flex flex-col gap-1 py-4">
        <p class="px-3 pb-1 pt-2 text-xs font-semibold uppercase tracking-wide text-ink-400">Categorías</p>
        {
          categories.map((category) => (
            <a
              href={`/categorias/${category.id}`}
              class="rounded-lg px-3 py-2 text-sm font-medium text-ink-700 transition-colors duration-150 hover:bg-brand-50"
              data-mobile-nav-link
            >
              {category.data.name}
            </a>
          ))
        }
        <div class="my-2 h-px bg-ink-100"></div>
        {
          navLinks.map((link) => (
            <a
              href={link.href}
              class="rounded-lg px-3 py-2 text-sm font-medium text-ink-700 transition-colors duration-150 hover:bg-brand-50"
              data-mobile-nav-link
            >
              {link.label}
            </a>
          ))
        }
        <Button href="javascript:void(0)" variant="primary" class="mt-3 w-full" data-lead-modal-trigger>Habla con un asesor</Button>
      </Container>
    </div>
  </div>
</header>

<script>
  const header = document.getElementById("site-header");
  const button = document.getElementById("mobile-menu-button");
  const menu = document.getElementById("mobile-menu");
  const bars = button?.querySelectorAll<HTMLSpanElement>("[data-menu-bar]");

  function setMenuOpen(open: boolean) {
    if (!button || !menu) return;
    button.setAttribute("aria-expanded", String(open));
    menu.classList.toggle("grid-rows-[0fr]", !open);
    menu.classList.toggle("opacity-0", !open);
    menu.classList.toggle("grid-rows-[1fr]", open);
    menu.classList.toggle("opacity-100", open);
    menu.classList.toggle("border-ink-100", open);
    menu.classList.toggle("border-transparent", !open);

    bars?.forEach((bar) => {
      const role = bar.dataset.menuBar;
      if (open) {
        if (role === "top") bar.style.transform = "translate(-50%, 0) rotate(45deg)";
        if (role === "middle") bar.style.opacity = "0";
        if (role === "bottom") bar.style.transform = "translate(-50%, 0) rotate(-45deg)";
      } else {
        if (role === "top") bar.style.transform = "translate(-50%, -6px) rotate(0deg)";
        if (role === "middle") bar.style.opacity = "1";
        if (role === "bottom") bar.style.transform = "translate(-50%, 5px) rotate(0deg)";
      }
    });
  }

  button?.addEventListener("click", () => {
    const isOpen = button.getAttribute("aria-expanded") === "true";
    setMenuOpen(!isOpen);
  });

  menu?.querySelectorAll<HTMLAnchorElement>("[data-mobile-nav-link]").forEach((link) => {
    link.addEventListener("click", () => setMenuOpen(false));
  });

  function updateHeaderShadow() {
    if (!header) return;
    const scrolled = window.scrollY > 8;
    header.classList.toggle("shadow-sm", scrolled);
    header.classList.toggle("shadow-ink-900/5", scrolled);
  }

  window.addEventListener("scroll", updateHeaderShadow, { passive: true });
  document.addEventListener("astro:page-load", updateHeaderShadow);
  updateHeaderShadow();
</script>
