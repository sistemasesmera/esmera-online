---
import type { CollectionEntry } from "astro:content";
import Icon from "./Icon.astro";

interface Props {
  category: CollectionEntry<"categories">;
  courseCount?: number;
}

const { category, courseCount } = Astro.props;
const iconName = (category.data.icon as "sparkles" | "shield" | "megaphone") ?? "sparkles";
---

<a
  href={`/categorias/${category.id}`}
  class="group flex flex-col gap-3 rounded-2xl border border-ink-100 bg-white p-6 transition-all duration-300 ease-out hover:-translate-y-1 hover:border-brand-200 hover:bg-brand-50 hover:shadow-lg hover:shadow-ink-900/5"
>
  <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-brand-100 text-brand-700 transition-transform duration-300 group-hover:scale-110 group-hover:rotate-6">
    <Icon name={iconName} class="h-5 w-5" />
  </div>
  <h3 class="font-display text-base font-semibold text-ink-900">{category.data.name}</h3>
  <p class="text-sm leading-relaxed text-ink-500">{category.data.description}</p>
  {typeof courseCount === "number" && (
    <span class="mt-1 text-xs font-medium text-brand-700">{courseCount} curso{courseCount === 1 ? "" : "s"}</span>
  )}
</a>
