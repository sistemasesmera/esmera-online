---
import Logo from "./Logo.astro";
import Container from "./ui/Container.astro";
import { getCollection } from "astro:content";

const categories = (await getCollection("categories")).sort((a, b) => a.data.order - b.data.order);
const year = new Date().getFullYear();
---

<footer class="bg-ink-950 text-ink-300">
  <Container class="grid grid-cols-1 gap-12 py-16 lg:grid-cols-4">
    <div>
      <Logo variant="light" />
      <p class="mt-4 max-w-xs text-sm leading-relaxed text-ink-400">
        Formación profesional online con acompañamiento real: tutorías, seguimiento y comunidad. Parte del grupo Esmera Global.
      </p>
    </div>

    <div>
      <h3 class="text-sm font-semibold text-white">Categorías</h3>
      <ul class="mt-4 space-y-2.5">
        {
          categories.map((category) => (
            <li>
              <a href={`/categorias/${category.id}`} class="text-sm text-ink-400 hover:text-brand-400">
                {category.data.name}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <div>
      <h3 class="text-sm font-semibold text-white">Esmera Online</h3>
      <ul class="mt-4 space-y-2.5">
        <li><a href="/nosotros" class="text-sm text-ink-400 hover:text-brand-400">Nosotros</a></li>
        <li><a href="/cursos" class="text-sm text-ink-400 hover:text-brand-400">Todos los cursos</a></li>
        <li><a href="/blog" class="text-sm text-ink-400 hover:text-brand-400">Blog</a></li>
        <li><a href="/contacto" class="text-sm text-ink-400 hover:text-brand-400">Contacto</a></li>
      </ul>
    </div>

    <div>
      <h3 class="text-sm font-semibold text-white">Habla con nosotros</h3>
      <ul class="mt-4 space-y-2.5">
        <li><a href="mailto:info@esmeraonline.com" class="text-sm text-ink-400 hover:text-brand-400">info@esmeraonline.com</a></li>
        <li><a href="/contacto" class="text-sm text-ink-400 hover:text-brand-400">Solicitar información</a></li>
      </ul>
    </div>
  </Container>

  <div class="border-t border-white/10">
    <Container class="flex flex-col gap-2 py-6 text-xs text-ink-500 sm:flex-row sm:items-center sm:justify-between">
      <p>&copy; {year} Esmera Online — Grupo Esmera Global. Todos los derechos reservados.</p>
      <div class="flex gap-5">
        <a href="/privacidad" class="hover:text-brand-400">Privacidad</a>
        <a href="/terminos" class="hover:text-brand-400">Términos</a>
        <a href="/cookies" class="hover:text-brand-400">Cookies</a>
      </div>
    </Container>
  </div>
</footer>
