---
import type { CollectionEntry } from "astro:content";
import { Image } from "astro:assets";

interface Props {
  instructor: CollectionEntry<"instructors">;
}

const { instructor } = Astro.props;
const initials = instructor.data.name
  .split(" ")
  .map((part) => part[0])
  .slice(0, 2)
  .join("");
---

<div class="group flex flex-col items-center rounded-3xl border border-ink-100 bg-white p-7 text-center transition-all duration-300 ease-out hover:-translate-y-1 hover:shadow-lg hover:shadow-ink-900/5">
  {
    instructor.data.photo ? (
      <Image
        src={instructor.data.photo}
        alt={instructor.data.name}
        width={96}
        height={96}
        class="h-20 w-20 rounded-full object-cover transition-transform duration-300 group-hover:scale-105"
      />
    ) : (
      <span class="flex h-20 w-20 items-center justify-center rounded-full bg-brand-100 text-xl font-semibold text-brand-700 transition-transform duration-300 group-hover:scale-105">
        {initials}
      </span>
    )
  }
  <h3 class="mt-4 font-display text-base font-semibold text-ink-900">{instructor.data.name}</h3>
  <p class="text-sm text-brand-600">{instructor.data.role}</p>
  <p class="mt-3 text-sm leading-relaxed text-ink-500">{instructor.data.bio}</p>
</div>
