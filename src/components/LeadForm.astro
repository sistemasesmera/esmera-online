---
import { getCollection } from "astro:content";

interface Props {
  presetCourse?: string;
  title?: string;
  subtitle?: string;
  variant?: "light" | "brand";
  showCourseField?: boolean;
  class?: string;
}

const {
  presetCourse,
  title = "Habla con un asesor de formación",
  subtitle = "Cuéntanos qué quieres conseguir y te ayudamos a elegir el camino formativo adecuado.",
  variant = "light",
  showCourseField = true,
  class: className = "",
} = Astro.props;

const courses = presetCourse || !showCourseField ? [] : await getCollection("courses");
const isBrand = variant === "brand";

const inputClass = isBrand
  ? "w-full rounded-lg border border-white/20 bg-white/10 px-4 py-2.5 text-sm text-white placeholder-white/50 outline-none transition-colors focus:border-white/50 focus:ring-2 focus:ring-white/20"
  : "w-full rounded-lg border border-ink-200 px-4 py-2.5 text-sm text-ink-900 outline-none transition-colors focus:border-brand-500 focus:ring-2 focus:ring-brand-100";

const labelClass = isBrand
  ? "mb-1.5 block font-mono text-xs font-medium uppercase tracking-wide text-white/70"
  : "mb-1.5 block font-mono text-xs font-medium uppercase tracking-wide text-ink-500";
---

<div
  class={`relative overflow-hidden rounded-3xl p-8 shadow-xl sm:p-10 ${isBrand ? "bg-brand-600 text-white shadow-brand-900/20" : "border border-ink-100 bg-white text-ink-900 shadow-ink-900/5"} ${className}`}
  data-variant={variant}
>
  {
    isBrand && (
      <>
        <div class="absolute inset-0 bg-grain"></div>
        <div class="glow-orb -right-16 -top-16 h-64 w-64 bg-brand-300/30"></div>
      </>
    )
  }

  <div class="relative">
    <h3 class={`font-display text-2xl font-semibold ${isBrand ? "text-white" : "text-ink-900"}`}>{title}</h3>
    <p class={`mt-2 text-sm leading-relaxed ${isBrand ? "text-white/85" : "text-ink-500"}`}>{subtitle}</p>

    <!-- Panel éxito real (201) -->
    <div id="lead-form-success" class="hidden mt-8 py-8 flex flex-col items-center gap-4 text-center">
      <span class={`flex h-20 w-20 items-center justify-center rounded-full ${isBrand ? "bg-white/20" : "bg-brand-50"}`}>
        <svg class={`h-10 w-10 ${isBrand ? "text-white" : "text-brand-600"}`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20 6 9 17l-5-5"/>
        </svg>
      </span>
      <p class={`text-sm leading-relaxed ${isBrand ? "text-white/85" : "text-ink-500"}`}>¡Recibido! Un asesor se pondrá en contacto contigo pronto.</p>
    </div>

    <!-- Panel duplicado (409) -->
    <div id="lead-form-duplicate" class="hidden mt-8 py-8 flex flex-col items-center gap-4 text-center">
      <span class={`flex h-20 w-20 items-center justify-center rounded-full ${isBrand ? "bg-white/10" : "bg-ink-50"}`}>
        <svg class={`h-10 w-10 ${isBrand ? "text-white/70" : "text-ink-400"}`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
        </svg>
      </span>
      <p class={`text-sm leading-relaxed ${isBrand ? "text-white/85" : "text-ink-500"}`}>Tu solicitud ha sido registrada. En breve nos pondremos en contacto contigo.</p>
    </div>

    <form id="lead-form" class="mt-8 space-y-4" novalidate>
      {presetCourse && <input type="hidden" name="courseOfInterest" value={presetCourse} />}

      <div>
        <label for="lead-name" class={labelClass}>Nombre completo</label>
        <input id="lead-name" name="name" type="text" required class={inputClass} placeholder="Tu nombre" />
      </div>

      <div>
        <label for="lead-phone" class={labelClass}>Teléfono</label>
        <input id="lead-phone" name="phone" type="tel" required class={inputClass} placeholder="612 345 678" />
        <p id="lead-phone-error" class={`mt-1 hidden text-xs ${isBrand ? "text-white/70" : "text-red-500"}`}>Introduce un número de teléfono válido.</p>
      </div>

      <div>
        <label for="lead-email" class={labelClass}>Email <span class={isBrand ? "text-white/50" : "text-ink-400"}>(opcional)</span></label>
        <input id="lead-email" name="email" type="email" class={inputClass} placeholder="tu@email.com" />
      </div>

      {
        !presetCourse && showCourseField && (
          <div>
            <label for="lead-course" class={labelClass}>Curso de interés</label>
            <select id="lead-course" name="courseOfInterest" class={inputClass}>
              <option value="">Aún no lo sé / quiero orientación</option>
              {courses.map((course) => (
                <option value={course.data.title}>{course.data.title}</option>
              ))}
            </select>
          </div>
        )
      }

      <div>
        <label for="lead-message" class={labelClass}>
          {showCourseField ? "¿Qué te gustaría conseguir?" : "Mensaje"} <span class={isBrand ? "text-white/50" : "text-ink-400"}>(opcional)</span>
        </label>
        <textarea
          id="lead-message"
          name="message"
          rows="3"
          class={inputClass}
          placeholder={showCourseField ? "Ej: quiero cambiar de profesión, especializarme, encontrar empleo..." : "Cuéntanos en qué podemos ayudarte"}
        ></textarea>
      </div>

      <button
        type="submit"
        class={
          isBrand
            ? "w-full rounded-lg bg-white px-6 py-3 font-display text-sm font-semibold text-brand-700 shadow-lg shadow-brand-900/20 transition-all duration-200 hover:-translate-y-0.5 hover:bg-white/90 disabled:opacity-60 disabled:cursor-not-allowed"
            : "w-full rounded-lg bg-brand-600 px-6 py-3 font-display text-sm font-semibold text-white shadow-[inset_0_1px_0_0_rgba(255,255,255,0.25),0_8px_20px_-10px_var(--color-brand-700)] transition-all duration-200 hover:-translate-y-0.5 hover:bg-brand-700 disabled:opacity-60 disabled:cursor-not-allowed"
        }
      >
        {showCourseField ? "Solicitar información" : "Enviar mensaje"}
      </button>

      <p id="lead-form-status" class={`text-center text-sm ${isBrand ? "text-white/80" : "text-ink-500"}`} role="status"></p>

      <p class={`text-center text-xs leading-relaxed ${isBrand ? "text-white/60" : "text-ink-400"}`}>
        Al enviar este formulario aceptas nuestra{" "}
        <a href="/privacidad" class={isBrand ? "underline hover:text-white" : "underline hover:text-brand-600"}>
          política de privacidad
        </a>.
      </p>
    </form>
  </div>
</div>

<style is:global>
  /* intl-tel-input — layout */
  .iti { width: 100%; }
  .iti__selected-flag {
    border-radius: 0.5rem 0 0 0.5rem;
    padding-inline: 0.75rem;
  }

  /* Dropdown: siempre texto oscuro sobre fondo blanco, independiente del tema */
  .iti__country-list {
    z-index: 50;
    background: #ffffff !important;
    color: #111827 !important;
    border-color: #e5e7eb !important;
    box-shadow: 0 4px 16px rgba(0,0,0,0.12);
  }
  .iti__country-list .iti__country-name,
  .iti__country-list .iti__dial-code {
    color: #111827 !important;
  }
  .iti__country-list .iti__country.iti__highlight,
  .iti__country-list .iti__country:hover {
    background: #f3f4f6 !important;
  }
  .iti__search-input {
    color: #111827 !important;
    background: #f9fafb !important;
    border-color: #e5e7eb !important;
  }

  /* Variante brand: flag button sobre fondo oscuro */
  [data-variant="brand"] .iti__selected-flag {
    background: rgba(255, 255, 255, 0.08);
    border-right: 1px solid rgba(255, 255, 255, 0.2);
  }
  [data-variant="brand"] .iti__selected-flag:hover {
    background: rgba(255, 255, 255, 0.15);
  }
  [data-variant="brand"] .iti__selected-dial-code {
    color: rgba(255, 255, 255, 0.85);
  }
  [data-variant="brand"] .iti__arrow {
    border-top-color: rgba(255, 255, 255, 0.6);
  }
</style>

<script>
  import intlTelInput from "intl-tel-input/intlTelInputWithUtils";
  import "intl-tel-input/styles";
  import { submitLead } from "../lib/leads";

  function initLeadForms() {
    document.querySelectorAll<HTMLFormElement>("#lead-form").forEach((form) => {
      if (form.dataset.bound) return;
      form.dataset.bound = "true";

      const phoneInput = form.querySelector<HTMLInputElement>("#lead-phone");
      const phoneError = form.querySelector<HTMLParagraphElement>("#lead-phone-error");
      const wrapper = form.closest<HTMLElement>(".relative");
      const successPanel = wrapper?.querySelector<HTMLElement>("#lead-form-success");
      const duplicatePanel = wrapper?.querySelector<HTMLElement>("#lead-form-duplicate");
      const status = form.querySelector<HTMLParagraphElement>("#lead-form-status");
      const submitBtn = form.querySelector<HTMLButtonElement>("button[type=submit]");

      const iti = phoneInput
        ? intlTelInput(phoneInput, { initialCountry: "es" })
        : null;

      function showPanel(panel: HTMLElement | null | undefined) {
        form.reset();
        form.classList.add("hidden");
        panel?.classList.remove("hidden");
      }

      form.addEventListener("submit", async (event) => {
        event.preventDefault();
        const data = new FormData(form);

        try {
          if (iti && !iti.isValidNumber()) {
            phoneError?.classList.remove("hidden");
            phoneInput?.focus();
            return;
          }
        } catch {
          // isValidNumber no disponible — dejamos pasar y el API valida
        }
        phoneError?.classList.add("hidden");

        if (submitBtn) submitBtn.disabled = true;
        if (status) status.textContent = "Enviando...";

        const result = await submitLead({
          name: String(data.get("name") ?? ""),
          email: String(data.get("email") ?? "") || undefined,
          phone: iti ? iti.getNumber() : String(data.get("phone") ?? ""),
          courseOfInterest: String(data.get("courseOfInterest") ?? "") || undefined,
          message: String(data.get("message") ?? "") || undefined,
        });

        if (result.ok) {
          showPanel(successPanel);
        } else if (result.duplicate) {
          showPanel(duplicatePanel);
        } else {
          if (status) status.textContent = "Ha ocurrido un error. Inténtalo de nuevo o llámanos directamente.";
          if (submitBtn) submitBtn.disabled = false;
        }
      });
    });
  }

  document.addEventListener("astro:page-load", initLeadForms);
</script>
