---
import type { CollectionEntry } from "astro:content";
import { Image } from "astro:assets";
import Icon from "./Icon.astro";

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;

const formattedDate = post.data.publishDate.toLocaleDateString("es-ES", { day: "numeric", month: "long", year: "numeric" });
---

<a
  href={`/blog/${post.id}`}
  class="group relative flex flex-col overflow-hidden rounded-3xl border border-ink-100 bg-white transition-all duration-300 ease-out hover:-translate-y-1.5 hover:border-brand-200 hover:shadow-xl hover:shadow-ink-900/10"
>
  <span class="absolute inset-x-0 top-0 z-10 h-[3px] origin-left scale-x-0 bg-brand-500 transition-transform duration-300 ease-out group-hover:scale-x-100"></span>
  <div class="relative aspect-video overflow-hidden">
    <Image
      src={post.data.coverImage}
      alt={post.data.title}
      width={600}
      height={338}
      class="h-full w-full object-cover transition-transform duration-500 ease-out group-hover:scale-110"
    />
    <span class="absolute left-4 top-4 inline-flex items-center rounded-full bg-white/90 px-3 py-1 font-mono text-[11px] font-semibold uppercase tracking-wide text-brand-700 shadow-sm backdrop-blur-sm">
      {post.data.category}
    </span>
  </div>
  <div class="flex flex-1 flex-col p-6">
    <h3 class="font-display text-lg font-semibold text-ink-900">{post.data.title}</h3>
    <p class="mt-2 flex-1 text-sm leading-relaxed text-ink-500">{post.data.description}</p>

    <div class="mt-5 flex items-center gap-4 border-t border-ink-100 pt-4 font-mono text-xs text-ink-500">
      <span class="inline-flex items-center gap-1.5">
        <Icon name="calendar" class="h-3.5 w-3.5" />
        {formattedDate}
      </span>
      <span class="inline-flex items-center gap-1.5">
        <Icon name="clock" class="h-3.5 w-3.5" />
        {post.data.readingTime}
      </span>
    </div>
  </div>
</a>
