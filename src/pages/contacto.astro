---
import Layout from "../layouts/Layout.astro";
import Container from "../components/ui/Container.astro";
import Eyebrow from "../components/ui/Eyebrow.astro";
import LeadForm from "../components/LeadForm.astro";
---

<Layout
  title="Contacto"
  description="¿Tienes una consulta, quieres formar a tu equipo o colaborar con Esmera Online? Escríbenos y te contactamos."
>
  <section class="relative overflow-hidden bg-gradient-to-b from-brand-50 to-white py-16 sm:py-20">
    <div class="absolute inset-x-0 top-0 -z-10 h-full bg-dot-grid-light opacity-60 [mask-image:radial-gradient(ellipse_70%_60%_at_50%_0%,black,transparent)]"></div>

    <Container class="relative max-w-3xl text-center" data-reveal>
      <Eyebrow class="justify-center">Contacto</Eyebrow>
      <h1 class="mt-4 font-display text-4xl font-semibold text-ink-900 sm:text-5xl">Hablemos</h1>
      <p class="mt-4 text-lg leading-relaxed text-ink-500">
        Cuéntanos qué necesitas y te contactamos lo antes posible.
      </p>
    </Container>
  </section>

  <section class="py-16">
    <Container class="max-w-2xl">
      <div data-reveal>
        <LeadForm
          title="Escríbenos"
          subtitle="Déjanos tus datos y un miembro de nuestro equipo te contactará."
          showCourseField={false}
        />
      </div>
    </Container>
  </section>
</Layout>
