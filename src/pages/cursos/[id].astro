---
import Layout from "../../layouts/Layout.astro";
import Container from "../../components/ui/Container.astro";
import Eyebrow from "../../components/ui/Eyebrow.astro";
import Button from "../../components/ui/Button.astro";
import CourseCard from "../../components/CourseCard.astro";
import LeadForm from "../../components/LeadForm.astro";
import Icon from "../../components/Icon.astro";
import { getCollection, getEntry, render } from "astro:content";
import { Image } from "astro:assets";
import type { GetStaticPaths } from "astro";

export const getStaticPaths = (async () => {
  const courses = await getCollection("courses");
  return courses.map((course) => ({ params: { id: course.id }, props: { course } }));
}) satisfies GetStaticPaths;

const { course } = Astro.props;
const { Content } = await render(course);

const categories = await Promise.all(course.data.categories.map((ref) => getEntry(ref)));
const relatedCourses = await Promise.all(course.data.relatedCourses.map((ref) => getEntry(ref)));

const displayTitle = course.data.certificadoProfesionalidad
  ? `${course.data.certificadoProfesionalidad.codigo} - ${course.data.title}`
  : course.data.title;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Course",
  name: course.data.title,
  description: course.data.shortDescription,
  provider: {
    "@type": "Organization",
    name: "Esmera Online",
    sameAs: "https://esmeraonline.com",
  },
  educationalLevel: course.data.level,
  hasCourseInstance: {
    "@type": "CourseInstance",
    courseMode: course.data.modality,
    duration: course.data.duration,
  },
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: course.data.faq.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: { "@type": "Answer", text: item.answer },
  })),
};

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Inicio", item: new URL("/", Astro.site).toString() },
    { "@type": "ListItem", position: 2, name: "Cursos", item: new URL("/cursos", Astro.site).toString() },
    { "@type": "ListItem", position: 3, name: course.data.title, item: new URL(`/cursos/${course.id}`, Astro.site).toString() },
  ],
};
---

<Layout title={course.data.title} description={course.data.shortDescription}>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
  </Fragment>

  <section class="relative overflow-hidden border-b border-ink-100 bg-gradient-to-b from-brand-50 to-white py-16 sm:py-20">
    <div class="absolute inset-x-0 top-0 -z-10 h-full bg-dot-grid-light opacity-60 [mask-image:radial-gradient(ellipse_70%_60%_at_50%_0%,black,transparent)]"></div>

    <Container class="relative">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-3">
        <div data-reveal class="lg:col-span-2">
          <div class="flex flex-wrap items-center gap-4">
            {categories.map((category) => (
              <a href={`/categorias/${category.id}`}>
                <Eyebrow>{category.data.name}</Eyebrow>
              </a>
            ))}
          </div>
          <h1 class="mt-4 font-display text-4xl font-semibold text-ink-900 sm:text-5xl">{displayTitle}</h1>
          <p class="mt-5 max-w-2xl text-lg leading-relaxed text-ink-500">{course.data.shortDescription}</p>

          <div class="mt-7 flex flex-wrap items-center gap-3">
            <span class="inline-flex items-center gap-2 rounded-full border border-ink-200 bg-white px-4 py-2 text-sm font-medium text-ink-700">
              <Icon name="clock" class="h-4 w-4 text-brand-600" />
              {course.data.duration}
            </span>
            {
              course.data.hasFinalProject && (
                <span class="inline-flex items-center gap-2 rounded-full border border-ink-200 bg-white px-4 py-2 text-sm font-medium text-ink-700">
                  <Icon name="briefcase" class="h-4 w-4 text-brand-600" />
                  Proyecto final
                </span>
              )
            }
            <span class="inline-flex items-center gap-2 rounded-full border border-ink-200 bg-white px-4 py-2 text-sm font-medium text-ink-700">
              <Icon name="calendar" class="h-4 w-4 text-brand-600" />
              Tutorías semanales
            </span>
          </div>

          {
            course.data.certificadoProfesionalidad && (
              <div data-reveal style="--reveal-delay: 80ms" class="mt-6 flex items-start gap-3 rounded-2xl border border-amber-200 bg-amber-50 px-5 py-4">
                <Icon name="award" class="mt-0.5 h-5 w-5 shrink-0 text-amber-600" />
                <p class="text-sm leading-relaxed text-amber-900">
                  Curso vinculado al <strong>Certificado de Profesionalidad {course.data.certificadoProfesionalidad.codigo} — {course.data.certificadoProfesionalidad.nombre}</strong>.{" "}
                  <a href="/certificados-de-profesionalidad" class="font-medium underline hover:text-amber-700">Más información</a>
                </p>
              </div>
            )
          }

          <div class="mt-8">
            <Button href="#informacion" variant="primary" size="lg">Solicitar información</Button>
          </div>
        </div>

        <div data-reveal style="--reveal-delay: 120ms" class="overflow-hidden rounded-3xl border border-ink-100">
          <Image src={course.data.coverImage} alt={course.data.title} width={500} height={281} class="aspect-video w-full object-cover transition-transform duration-500 hover:scale-105" />
        </div>
      </div>
    </Container>
  </section>

  <section class="py-16">
    <Container>
      <div class="grid grid-cols-1 gap-16 lg:grid-cols-3">
        <div class="space-y-16 lg:col-span-2">
          <div data-reveal>
            <h2 class="font-display text-2xl font-semibold text-ink-900">Lo que vas a conseguir</h2>
            <ul class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-2">
              {
                course.data.objectives.map((objective, index) => (
                  <li
                    data-reveal
                    style={`--reveal-delay: ${(index % 2) * 80}ms`}
                    class="group flex items-start gap-3 rounded-xl border border-ink-100 bg-white p-4 transition-all duration-300 ease-out hover:-translate-y-0.5 hover:border-brand-200 hover:shadow-md hover:shadow-ink-900/5"
                  >
                    <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-brand-100 text-brand-700 transition-transform duration-300 group-hover:-rotate-6">
                      <Icon name={objective.icon} class="h-4 w-4" />
                    </div>
                    <p class="mt-0.5 text-sm leading-relaxed text-ink-900">{objective.text}</p>
                  </li>
                ))
              }
            </ul>
          </div>

          <div data-reveal>
            <h2 class="font-display text-2xl font-semibold text-ink-900">Metodología</h2>
            <div class="prose mt-6 max-w-none text-ink-600">
              <Content />
            </div>
          </div>

          <div data-reveal>
            <h2 class="font-display text-2xl font-semibold text-ink-900">Contenidos del curso</h2>
            <div class="mt-6 space-y-5 border-l-2 border-ink-100 pl-6">
              {
                course.data.contents.map((module, index) => (
                  <div data-reveal style={`--reveal-delay: ${(index % 5) * 60}ms`} class="relative">
                    <span class="absolute -left-[1.65rem] top-1 h-2.5 w-2.5 rounded-full bg-brand-500" />
                    <p class="text-sm font-semibold text-ink-900">{module.title}</p>
                    {module.description && <p class="mt-1 text-sm leading-relaxed text-ink-500">{module.description}</p>}
                  </div>
                ))
              }
            </div>
            {
              course.data.hasFinalProject && (
                <p class="mt-4 text-sm font-medium text-brand-700">✓ Este curso incluye proyecto final.</p>
              )
            }
          </div>

          {
            course.data.careerOutcomes && course.data.careerOutcomes.length > 0 && (
              <div data-reveal>
                <h2 class="font-display text-2xl font-semibold text-ink-900">Salidas profesionales</h2>
                <p class="mt-2 text-sm text-ink-500">Perfiles a los que puedes optar al terminar este curso.</p>
                <div class="mt-6 grid grid-cols-2 gap-4 sm:grid-cols-4">
                  {course.data.careerOutcomes.map((outcome, index) => (
                    <div data-reveal style={`--reveal-delay: ${(index % 4) * 60}ms`} class="rounded-2xl border border-ink-100 p-4">
                      <p class="text-sm font-semibold text-ink-900">{outcome.title}</p>
                      {outcome.description && <p class="mt-1 text-xs leading-relaxed text-ink-500">{outcome.description}</p>}
                    </div>
                  ))}
                </div>
              </div>
            )
          }

          <div data-reveal>
            <h2 class="font-display text-2xl font-semibold text-ink-900">Preguntas frecuentes</h2>
            <div class="mt-6 space-y-3">
              {
                course.data.faq.map((item, index) => (
                  <details
                    data-reveal
                    style={`--reveal-delay: ${index * 60}ms`}
                    class="group rounded-2xl border border-ink-100 p-5 transition-colors duration-200 open:border-brand-200 open:bg-brand-50/40"
                  >
                    <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-sm font-semibold text-ink-900">
                      {item.question}
                      <svg
                        width="14"
                        height="8"
                        viewBox="0 0 14 8"
                        fill="none"
                        class="shrink-0 text-brand-600 transition-transform duration-300 group-open:rotate-180"
                      >
                        <path d="M1 1l6 6 6-6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
                      </svg>
                    </summary>
                    <p class="mt-3 animate-[fadeIn_0.3s_ease-out] text-sm leading-relaxed text-ink-500">{item.answer}</p>
                  </details>
                ))
              }
            </div>
          </div>

          {
            relatedCourses.length > 0 && (
              <div data-reveal>
                <h2 class="font-display text-2xl font-semibold text-ink-900">Cursos relacionados</h2>
                <div class="mt-6 grid grid-cols-1 gap-6 sm:grid-cols-2">
                  {relatedCourses.map((related) => related && <CourseCard course={related} />)}
                </div>
              </div>
            )
          }
        </div>

        <aside class="lg:col-span-1">
          <div data-reveal style="--reveal-delay: 150ms" class="sticky top-24 space-y-6" id="informacion">
            <LeadForm
              presetCourse={course.data.title}
              title="Solicita información"
              subtitle="Te contamos fechas, precio y todo lo que necesitas para empezar."
              variant="brand"
            />
          </div>
        </aside>
      </div>
    </Container>
  </section>
</Layout>
