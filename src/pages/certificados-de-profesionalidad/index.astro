---
import Layout from "../../layouts/Layout.astro";
import Container from "../../components/ui/Container.astro";
import Eyebrow from "../../components/ui/Eyebrow.astro";
import Button from "../../components/ui/Button.astro";
import Icon from "../../components/Icon.astro";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";

const allCourses = await getCollection("courses");
const courses = allCourses.filter((course) => course.data.certificadoProfesionalidad);

const beneficios = [
  {
    title: "Validez en toda España",
    description: "Es una acreditación oficial reconocida en todo el territorio nacional, no solo por Esmera Online.",
    icon: "compass" as const,
  },
  {
    title: "Reconocido por empresas y administraciones",
    description: "Acredita tus competencias profesionales ante cualquier empleador público o privado.",
    icon: "briefcase" as const,
  },
  {
    title: "Mismo valor que la FP para el empleo",
    description: "Equivale, a efectos de acreditación de competencias, a la Formación Profesional para el Empleo.",
    icon: "shield" as const,
  },
  {
    title: "Suma en oposiciones y bolsas de trabajo",
    description: "Puede valorarse como mérito en procesos de selección de empleo público y privado.",
    icon: "award" as const,
  },
];

const niveles = [
  {
    nivel: "Nivel 1",
    title: "Competencias básicas",
    description: "Tareas sencillas y bien definidas, ejecutadas con autonomía limitada y bajo supervisión.",
  },
  {
    nivel: "Nivel 2",
    title: "Autonomía técnica",
    description: "Responsabilidad sobre tareas completas dentro de un proceso, con autonomía técnica para resolverlas.",
  },
  {
    nivel: "Nivel 3",
    title: "Responsabilidad y coordinación",
    description: "Mayor amplitud técnica, capacidad de coordinación y conocimientos más especializados del sector.",
  },
];

const preguntasFrecuentes = [
  {
    question: "¿Quién emite el Certificado de Profesionalidad?",
    answer:
      "Lo emite el SEPE (Servicio Público de Empleo Estatal) o el organismo autonómico equivalente. Esmera Online está trabajando en la homologación necesaria para impartir formación conducente a su obtención.",
  },
  {
    question: "¿Es lo mismo que el diploma propio de Esmera Online?",
    answer:
      "No. El diploma propio certifica que has completado el curso con nosotros; el Certificado de Profesionalidad es, además, una acreditación oficial del Estado con validez en toda España.",
  },
  {
    question: "¿Necesito cumplir algún requisito de acceso?",
    answer:
      "Depende del nivel del certificado y, en algunos casos, de tu formación o experiencia previa. Te lo confirmamos al solicitar información sobre el curso concreto.",
  },
  {
    question: "¿Cómo se obtiene exactamente?",
    answer:
      "Completando los módulos formativos del curso y, según el certificado, superando una fase de evaluación práctica en un centro de trabajo.",
  },
];

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Inicio", item: new URL("/", Astro.site).toString() },
    { "@type": "ListItem", position: 2, name: "Certificados de Profesionalidad", item: new URL("/certificados-de-profesionalidad", Astro.site).toString() },
  ],
};
---

<Layout
  title="Certificados de Profesionalidad"
  description="Qué es un Certificado de Profesionalidad y qué cursos de Esmera Online están vinculados a esta acreditación oficial."
>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
  </Fragment>

  <section class="relative overflow-hidden border-b border-ink-100 bg-gradient-to-b from-brand-50 to-white py-16 sm:py-20">
    <div class="absolute inset-x-0 top-0 -z-10 h-full bg-dot-grid-light opacity-60 [mask-image:radial-gradient(ellipse_70%_60%_at_50%_0%,black,transparent)]"></div>

    <Container class="relative max-w-3xl" data-reveal>
      <Eyebrow>Acreditación oficial</Eyebrow>
      <h1 class="mt-4 font-display text-4xl font-semibold text-ink-900 sm:text-5xl">Certificados de Profesionalidad</h1>
      <p class="mt-6 text-lg leading-relaxed text-ink-500">
        Un Certificado de Profesionalidad es una acreditación oficial, regulada por el SEPE (Servicio Público de Empleo
        Estatal), que reconoce las competencias profesionales necesarias para desempeñar una actividad laboral. A
        diferencia de un diploma privado, tiene validez en todo el territorio español y es reconocido directamente por
        empresas y administraciones públicas.
      </p>
      <p class="mt-4 text-lg leading-relaxed text-ink-500">
        Cada certificado se organiza en módulos formativos vinculados a "unidades de competencia" — los bloques de
        conocimiento y práctica que un profesional debe dominar en su sector.
      </p>
    </Container>
  </section>

  <!-- Beneficios -->
  <section class="py-16">
    <Container>
      <div data-reveal class="mx-auto max-w-2xl text-center">
        <Eyebrow class="justify-center">Por qué importa</Eyebrow>
        <h2 class="mt-4 font-display text-3xl font-semibold text-ink-900 sm:text-4xl">Más que un diploma</h2>
        <p class="mt-4 text-base leading-relaxed text-ink-500">
          Un Certificado de Profesionalidad pesa distinto en tu carrera: lo respalda el Estado, no solo el centro que te ha formado.
        </p>
      </div>

      <div class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {
          beneficios.map((beneficio, index) => (
            <div
              data-reveal
              style={`--reveal-delay: ${(index % 4) * 80}ms`}
              class="group rounded-2xl border border-ink-100 p-6 transition-all duration-300 ease-out hover:-translate-y-1 hover:border-brand-200 hover:shadow-lg hover:shadow-ink-900/5"
            >
              <div class="mb-4 flex h-11 w-11 items-center justify-center rounded-xl bg-brand-100 text-brand-700 transition-transform duration-300 group-hover:-rotate-6">
                <Icon name={beneficio.icon} class="h-5 w-5" />
              </div>
              <h3 class="font-display text-base font-semibold text-ink-900">{beneficio.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-ink-500">{beneficio.description}</p>
            </div>
          ))
        }
      </div>
    </Container>
  </section>

  <!-- Niveles -->
  <section class="border-t border-ink-100 bg-ink-50/60 py-16">
    <Container>
      <div data-reveal>
        <Eyebrow>Estructura</Eyebrow>
        <h2 class="mt-4 font-display text-2xl font-semibold text-ink-900 sm:text-3xl">Los 3 niveles de cualificación</h2>
        <p class="mt-3 max-w-2xl text-base leading-relaxed text-ink-500">
          Cada Certificado de Profesionalidad pertenece a uno de estos tres niveles, según la complejidad y autonomía que exige.
        </p>
      </div>

      <div class="mt-10 grid grid-cols-1 gap-5 sm:grid-cols-3">
        {
          niveles.map((item, index) => (
            <div data-reveal style={`--reveal-delay: ${index * 80}ms`} class="rounded-2xl border border-ink-100 bg-white p-6">
              <span class="font-mono text-xs font-semibold uppercase tracking-wide text-brand-600">{item.nivel}</span>
              <h3 class="mt-2 font-display text-base font-semibold text-ink-900">{item.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-ink-500">{item.description}</p>
            </div>
          ))
        }
      </div>
    </Container>
  </section>

  <section class="py-16">
    <Container>
      <div data-reveal class="flex flex-col items-start justify-between gap-4 sm:flex-row sm:items-end">
        <div>
          <Eyebrow>Formación oficial</Eyebrow>
          <h2 class="mt-4 font-display text-2xl font-semibold text-ink-900 sm:text-3xl">
            Certificados de Profesionalidad que tenemos
          </h2>
        </div>
        {
          courses.length > 1 && (
            <div class="flex gap-3">
              <button
                id="cert-carousel-prev"
                type="button"
                aria-label="Certificado anterior"
                class="flex h-10 w-10 items-center justify-center rounded-full border border-ink-200 text-ink-700 transition-colors duration-150 hover:border-brand-300 hover:text-brand-700"
              >
                <svg width="8" height="14" viewBox="0 0 8 14" fill="none">
                  <path d="M7 1L1 7l6 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </button>
              <button
                id="cert-carousel-next"
                type="button"
                aria-label="Siguiente certificado"
                class="flex h-10 w-10 items-center justify-center rounded-full border border-ink-200 text-ink-700 transition-colors duration-150 hover:border-brand-300 hover:text-brand-700"
              >
                <svg width="8" height="14" viewBox="0 0 8 14" fill="none">
                  <path d="M1 1l6 6-6 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </button>
            </div>
          )
        }
      </div>

      {
        courses.length === 0 && (
          <div data-reveal class="mt-10 flex flex-col items-start gap-4 rounded-3xl border border-ink-100 bg-ink-50/60 p-8 sm:flex-row sm:items-center sm:justify-between">
            <p class="text-ink-600">
              ¿Quieres saber más sobre nuestros Certificados de Profesionalidad? Escríbenos y te contamos.
            </p>
            <Button href="javascript:void(0)" variant="primary" size="lg" class="shrink-0" data-lead-modal-trigger>
              Contáctanos
            </Button>
          </div>
        )
      }

      <div
        id="cert-carousel"
        data-reveal
        style="--reveal-delay: 80ms"
        class="no-scrollbar mt-10 flex gap-6 overflow-x-auto pb-2 [scroll-snap-type:x_mandatory]"
      >
        {
          courses.map((course) => {
            const cert = course.data.certificadoProfesionalidad!;
            return (
              <a
                href={`/cursos/${course.id}`}
                data-cert-card
                class="group flex w-[300px] shrink-0 flex-col overflow-hidden rounded-3xl border border-ink-100 [scroll-snap-align:start] transition-all duration-300 ease-out hover:-translate-y-1.5 hover:border-brand-200 hover:shadow-xl hover:shadow-ink-900/10 sm:w-[340px]"
              >
                <div class="aspect-video overflow-hidden">
                  <Image
                    src={course.data.coverImage}
                    alt={cert.nombre}
                    width={400}
                    height={225}
                    class="h-full w-full object-cover transition-transform duration-500 ease-out group-hover:scale-110"
                  />
                </div>
                <div class="flex flex-1 flex-col p-6">
                  <span class="inline-flex w-fit items-center gap-1.5 rounded-full bg-amber-50 px-2.5 py-1 font-mono text-[11px] font-medium uppercase tracking-wide text-amber-700">
                    <Icon name="award" class="h-3 w-3" />
                    {cert.estado}
                  </span>
                  <p class="mt-4 font-mono text-xs font-semibold uppercase tracking-wide text-brand-600">{cert.familia} · {cert.nivel}</p>
                  <h3 class="mt-2 font-display text-lg font-semibold text-ink-900">
                    <span class="text-brand-600">{cert.codigo}</span> · {cert.nombre}
                  </h3>
                  <p class="mt-4 flex-1 text-sm leading-relaxed text-ink-500">Vinculado al curso "{course.data.title}".</p>
                  <span class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-brand-700">
                    Ver curso
                    <span aria-hidden="true" class="transition-transform duration-200 group-hover:translate-x-1">→</span>
                  </span>
                </div>
              </a>
            );
          })
        }
      </div>
    </Container>
  </section>

  <script>
    function initCertCarousel() {
      const carousel = document.getElementById("cert-carousel");
      const prev = document.getElementById("cert-carousel-prev");
      const next = document.getElementById("cert-carousel-next");
      if (!carousel) return;

      const scrollByCard = (direction: number) => {
        const card = carousel.querySelector<HTMLElement>("[data-cert-card]");
        const amount = (card?.offsetWidth ?? 320) + 24;
        carousel.scrollBy({ left: direction * amount, behavior: "smooth" });
      };

      prev?.addEventListener("click", () => scrollByCard(-1));
      next?.addEventListener("click", () => scrollByCard(1));
    }

    document.addEventListener("astro:page-load", initCertCarousel);
  </script>

  <!-- FAQ -->
  <section class="border-t border-ink-100 py-16">
    <Container class="max-w-3xl">
      <div data-reveal>
        <Eyebrow>Dudas frecuentes</Eyebrow>
        <h2 class="mt-4 font-display text-2xl font-semibold text-ink-900 sm:text-3xl">Preguntas sobre los certificados</h2>
      </div>

      <div class="mt-8 space-y-3">
        {
          preguntasFrecuentes.map((item, index) => (
            <details
              data-reveal
              style={`--reveal-delay: ${index * 60}ms`}
              class="group rounded-2xl border border-ink-100 p-5 transition-colors duration-200 open:border-brand-200 open:bg-brand-50/40"
            >
              <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-sm font-semibold text-ink-900">
                {item.question}
                <svg
                  width="14"
                  height="8"
                  viewBox="0 0 14 8"
                  fill="none"
                  class="shrink-0 text-brand-600 transition-transform duration-300 group-open:rotate-180"
                >
                  <path d="M1 1l6 6 6-6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </summary>
              <p class="mt-3 animate-[fadeIn_0.3s_ease-out] text-sm leading-relaxed text-ink-500">{item.answer}</p>
            </details>
          ))
        }
      </div>
    </Container>
  </section>

  <section class="border-t border-ink-100 bg-ink-950 py-16 text-white">
    <Container class="flex flex-col items-start gap-6 sm:flex-row sm:items-center sm:justify-between">
      <div data-reveal>
        <h2 class="font-display text-2xl font-semibold sm:text-3xl">¿Quieres más información sobre estos certificados?</h2>
        <p class="mt-2 max-w-xl text-ink-300">Déjanos tus datos y te contamos todo sobre convocatorias, requisitos y plazos.</p>
      </div>
      <Button href="javascript:void(0)" variant="primary" size="lg" data-lead-modal-trigger>Solicitar información</Button>
    </Container>
  </section>
</Layout>
