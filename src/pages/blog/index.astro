---
import Layout from "../../layouts/Layout.astro";
import Container from "../../components/ui/Container.astro";
import Eyebrow from "../../components/ui/Eyebrow.astro";
import Icon from "../../components/Icon.astro";
import BlogPostCard from "../../components/BlogPostCard.astro";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";

const posts = (await getCollection("blog")).sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
const [spotlight, ...rest] = posts;

const spotlightDate = spotlight?.data.publishDate.toLocaleDateString("es-ES", { day: "numeric", month: "long", year: "numeric" });
---

<Layout
  title="Blog"
  description="El blog de Esmera Online: artículos sobre formación, empleo y tendencias de cada sector."
>
  <section class="relative overflow-hidden border-b border-ink-100 bg-gradient-to-b from-brand-50 to-white py-16 sm:py-20">
    <div class="absolute inset-x-0 top-0 -z-10 h-full bg-dot-grid-light opacity-60 [mask-image:radial-gradient(ellipse_70%_60%_at_50%_0%,black,transparent)]"></div>

    <Container class="relative" data-reveal>
      <Eyebrow>Blog de Esmera Online</Eyebrow>
      <h1 class="mt-4 font-display text-4xl font-semibold text-ink-900 sm:text-5xl">Aprende algo nuevo cada semana</h1>
      <p class="mt-4 max-w-2xl text-lg leading-relaxed text-ink-500">
        Artículos sobre formación, empleo y tendencias de cada sector.
      </p>
    </Container>
  </section>

  {
    spotlight && (
      <section class="py-16">
        <Container>
          <a
            href={`/blog/${spotlight.id}`}
            data-reveal
            class="group grid grid-cols-1 overflow-hidden rounded-3xl border border-ink-100 transition-all duration-300 ease-out hover:border-brand-200 hover:shadow-xl hover:shadow-ink-900/10 lg:grid-cols-2"
          >
            <div class="aspect-video overflow-hidden lg:aspect-auto">
              <Image
                src={spotlight.data.coverImage}
                alt={spotlight.data.title}
                width={700}
                height={500}
                class="h-full w-full object-cover transition-transform duration-500 ease-out group-hover:scale-105"
              />
            </div>
            <div class="flex flex-col justify-center p-8 sm:p-10">
              <span class="inline-flex w-fit items-center rounded-full bg-brand-50 px-3 py-1 font-mono text-[11px] font-semibold uppercase tracking-wide text-brand-700">
                Último artículo · {spotlight.data.category}
              </span>
              <h2 class="mt-4 font-display text-2xl font-semibold text-ink-900 sm:text-3xl">{spotlight.data.title}</h2>
              <p class="mt-4 text-base leading-relaxed text-ink-500">{spotlight.data.description}</p>

              <div class="mt-6 flex items-center gap-5 font-mono text-xs text-ink-500">
                <span class="inline-flex items-center gap-1.5">
                  <Icon name="calendar" class="h-3.5 w-3.5" />
                  {spotlightDate}
                </span>
                <span class="inline-flex items-center gap-1.5">
                  <Icon name="clock" class="h-3.5 w-3.5" />
                  {spotlight.data.readingTime}
                </span>
              </div>

              <span class="mt-6 inline-flex items-center gap-1 text-sm font-semibold text-brand-700">
                Leer artículo
                <span aria-hidden="true" class="transition-transform duration-200 group-hover:translate-x-1">→</span>
              </span>
            </div>
          </a>
        </Container>
      </section>
    )
  }

  <section class="border-t border-ink-100 py-16">
    <Container>
      {
        rest.length > 0 && (
          <div data-reveal>
            <Eyebrow>Más artículos</Eyebrow>
          </div>
        )
      }
      <div class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          rest.map((post, index) => (
            <div data-reveal style={`--reveal-delay: ${(index % 3) * 80}ms`}>
              <BlogPostCard post={post} />
            </div>
          ))
        }
      </div>
    </Container>
  </section>
</Layout>
