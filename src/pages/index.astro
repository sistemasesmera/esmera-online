---
import Layout from "../layouts/Layout.astro";
import Container from "../components/ui/Container.astro";
import Eyebrow from "../components/ui/Eyebrow.astro";
import Button from "../components/ui/Button.astro";
import CourseCard from "../components/CourseCard.astro";
import CategoryCard from "../components/CategoryCard.astro";
import Icon from "../components/Icon.astro";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import heroImage from "../assets/hero/hero-study.jpg";

const categories = (await getCollection("categories")).sort((a, b) => a.data.order - b.data.order);
const courses = await getCollection("courses");
const featuredCourses = courses.filter((course) => course.data.featured).sort((a, b) => a.data.order - b.data.order);
const companies = await getCollection("companies");

const courseCountByCategory = new Map<string, number>();
for (const course of courses) {
  const key = course.data.category.id;
  courseCountByCategory.set(key, (courseCountByCategory.get(key) ?? 0) + 1);
}

const journeySteps = [
  { title: "Bienvenida personalizada", description: "Accedes de inmediato y un tutor de bienvenida te guía en tus primeros pasos." },
  { title: "Tutor asignado", description: "Tienes un tutor de referencia durante todo el curso, no un foro genérico." },
  { title: "Tutorías semanales", description: "Resuelves dudas en directo cada semana, no solo ves vídeos en soledad." },
  { title: "Proyecto y comunidad", description: "Aplicas lo aprendido en un proyecto real y conectas con tu comunidad de alumnos." },
  { title: "Certificado profesional", description: "Terminas con un diploma o certificado profesional que demuestra tu nueva capacidad." },
];

const benefits = [
  { title: "Acompañamiento real", description: "Tutor asignado y seguimiento personalizado, no estás solo frente a una pantalla.", icon: "chat" as const },
  { title: "Tutorías semanales en directo", description: "Resuelve tus dudas en tiempo real con profesionales en activo.", icon: "calendar" as const },
  { title: "Comunidad y networking", description: "Conecta con compañeros y profesionales de tu mismo sector.", icon: "users" as const },
  { title: "Proyectos reales", description: "Aplica lo aprendido en proyectos que puedes mostrar en tu portfolio profesional.", icon: "briefcase" as const },
  { title: "Contenidos siempre actualizados", description: "Formación al día con lo que el mercado laboral demanda hoy.", icon: "refresh" as const },
  { title: "Orientación profesional", description: "Te ayudamos a dar el siguiente paso: empleo, especialización o emprendimiento.", icon: "compass" as const },
];

const delayStyle = (index: number, step = 80) => `--reveal-delay: ${index * step}ms`;
---

<Layout
  title="Esmera Online — Formación profesional online con acompañamiento real"
  description="Formación online en IA, marketing, desarrollo, diseño y más sectores. Tutorías semanales, tutor asignado, comunidad y certificación profesional."
>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-white py-20 sm:py-28">
    <div class="absolute inset-x-0 top-0 -z-10 h-[640px] bg-gradient-to-b from-brand-50 to-white"></div>
    <div class="absolute inset-x-0 top-0 -z-10 h-[640px] bg-dot-grid-light opacity-60 [mask-image:radial-gradient(ellipse_70%_60%_at_50%_0%,black,transparent)]"></div>
    <div class="glow-orb -right-32 top-10 -z-10 h-96 w-96 bg-brand-300/25"></div>

    <Container class="relative">
      <div class="grid grid-cols-1 items-center gap-16 lg:grid-cols-2">
        <div>
          <h1 data-reveal style={delayStyle(1)} class="font-display text-4xl font-semibold text-ink-900 sm:text-6xl">
            No vendemos cursos.<br />
            <span class="relative text-brand-600">
              Te llevamos a tu próximo paso profesional.
              <svg viewBox="0 0 360 12" preserveAspectRatio="none" class="absolute -bottom-1 left-0 h-2.5 w-full text-brand-300/70 sm:-bottom-2">
                <path d="M2 9.5C60 2 280 1 358 8" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" />
              </svg>
            </span>
          </h1>
          <p data-reveal style={delayStyle(2)} class="mt-7 max-w-xl text-lg leading-relaxed text-ink-500">
            Formación online con tutor asignado, tutorías semanales y comunidad real — para conseguir empleo, cambiar de profesión o especializarte de verdad.
          </p>
          <div data-reveal style={delayStyle(3)} class="mt-10 flex flex-col items-start gap-3 sm:flex-row">
            <Button href="/cursos" variant="primary" size="lg">Explorar cursos</Button>
            <Button href="javascript:void(0)" variant="secondary" size="lg" data-lead-modal-trigger>Habla con un asesor</Button>
          </div>
        </div>

        <div data-reveal style={delayStyle(2)} class="relative mx-auto w-full max-w-md lg:max-w-none">
          <div class="absolute -inset-3 -z-10 rounded-[2.5rem] border-2 border-brand-200 lg:rotate-2"></div>
          <div class="relative aspect-[4/5] overflow-hidden rounded-[2rem] shadow-2xl shadow-ink-900/15">
            <Image src={heroImage} alt="Alumno organizando su plan de formación" width={700} height={875} class="h-full w-full object-cover" />
            <div class="absolute inset-0 bg-gradient-to-t from-ink-950/30 via-transparent to-transparent"></div>
          </div>

          <div class="absolute -left-4 top-8 flex items-center gap-3 rounded-2xl bg-white/90 p-4 shadow-xl shadow-ink-900/10 backdrop-blur-sm animate-float sm:-left-8">
            <div class="flex text-brand-500">
              {Array.from({ length: 5 }).map(() => (
                <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor">
                  <path d="M8 0l2.47 5.01 5.53.8-4 3.9.94 5.5L8 12.6l-4.94 2.6.94-5.5-4-3.9 5.53-.8L8 0z" />
                </svg>
              ))}
            </div>
            <div>
              <p class="font-mono text-sm font-semibold text-ink-900">4.9/5</p>
              <p class="text-xs text-ink-500">valoración de alumnos</p>
            </div>
          </div>

          <div
            class="absolute -right-4 bottom-8 flex items-center gap-3 rounded-2xl bg-white/90 p-4 shadow-xl shadow-ink-900/10 backdrop-blur-sm animate-float sm:-right-8"
            style="animation-delay: 1.2s"
          >
            <span class="flex h-10 w-10 items-center justify-center rounded-full bg-brand-100 text-brand-700">
              <Icon name="users" class="h-5 w-5" />
            </span>
            <div>
              <p class="font-mono text-sm font-semibold text-ink-900">+1.200</p>
              <p class="text-xs text-ink-500">alumnos formados</p>
            </div>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- Beneficios -->
  <section class="py-24">
    <Container>
      <div data-reveal class="mx-auto max-w-2xl text-center">
        <h2 class="font-display text-3xl font-semibold text-ink-900 sm:text-4xl">
          Nuestra ventaja no son los vídeos
        </h2>
        <p class="mt-4 text-base leading-relaxed text-ink-500">
          Es el acompañamiento real durante todo el proceso, de principio a fin.
        </p>
      </div>

      <div class="mt-14 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          benefits.map((benefit, index) => (
            <div
              data-reveal
              style={delayStyle(index % 3)}
              class="group relative rounded-2xl border border-ink-100 p-6 transition-all duration-300 ease-out hover:-translate-y-1 hover:border-brand-200 hover:shadow-lg hover:shadow-ink-900/5"
            >
              <span class="absolute right-5 top-5 font-mono text-xs text-ink-200 transition-colors duration-300 group-hover:text-brand-300">
                {String(index + 1).padStart(2, "0")}
              </span>
              <div class="mb-4 flex h-11 w-11 items-center justify-center rounded-xl bg-brand-100 text-brand-700 transition-transform duration-300 group-hover:-rotate-6">
                <Icon name={benefit.icon} class="h-5 w-5" />
              </div>
              <h3 class="font-display text-base font-semibold text-ink-900">{benefit.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-ink-500">{benefit.description}</p>
            </div>
          ))
        }
      </div>
    </Container>
  </section>

  <!-- Cómo funciona -->
  <section class="relative overflow-hidden bg-ink-950 py-24 text-white">
    <div class="absolute inset-0 bg-grain"></div>
    <div class="absolute inset-0 bg-dot-grid opacity-[0.15] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_40%,black,transparent)]"></div>
    <div class="glow-orb left-1/2 top-0 h-80 w-80 -translate-x-1/2 bg-brand-500/20"></div>

    <Container class="relative">
      <div data-reveal class="mx-auto max-w-2xl text-center">
        <h2 class="font-display text-3xl font-semibold sm:text-4xl">Tu recorrido como alumno</h2>
      </div>

      <div class="mt-16 grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-5">
        {
          journeySteps.map((step, index) => (
            <div data-reveal style={delayStyle(index)} class="relative border-t border-white/10 pt-5">
              <span class="font-mono text-sm text-brand-400">{String(index + 1).padStart(2, "0")}</span>
              <h3 class="mt-3 font-display text-base font-semibold">{step.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-ink-300">{step.description}</p>
            </div>
          ))
        }
      </div>
    </Container>
  </section>

  <!-- Categorías -->
  <section class="py-24">
    <Container>
      <div data-reveal class="flex flex-col items-start justify-between gap-4 sm:flex-row sm:items-end">
        <div>
          <Eyebrow>Sectores</Eyebrow>
          <h2 class="mt-3 font-display text-3xl font-semibold text-ink-900 sm:text-4xl">Formación en múltiples sectores</h2>
        </div>
        <Button href="/cursos" variant="ghost">Ver todos los cursos →</Button>
      </div>

      <div class="mt-12 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {
          categories.map((category, index) => (
            <div data-reveal style={delayStyle(index % 3)}>
              <CategoryCard category={category} courseCount={courseCountByCategory.get(category.id) ?? 0} />
            </div>
          ))
        }
      </div>
    </Container>
  </section>

  <!-- Cursos destacados -->
  <section class="bg-ink-50/60 py-24">
    <Container>
      <div data-reveal class="flex flex-col items-start justify-between gap-4 sm:flex-row sm:items-end">
        <div>
          <Eyebrow>Catálogo</Eyebrow>
          <h2 class="mt-3 font-display text-3xl font-semibold text-ink-900 sm:text-4xl">Empieza por aquí</h2>
        </div>
        <Button href="/cursos" variant="ghost">Ver todos los cursos →</Button>
      </div>

      <div class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {
          featuredCourses.map((course, index) => (
            <div data-reveal style={delayStyle(index % 4)}>
              <CourseCard course={course} />
            </div>
          ))
        }
      </div>
    </Container>
  </section>

  <!-- Empresas colaboradoras -->
  <section class="py-20" data-reveal>
    <Container>
      <p class="text-center font-mono text-xs font-medium uppercase tracking-[0.18em] text-ink-400">Empresas que confían en nuestro talento formado</p>
    </Container>

    <p class="sr-only">Empresas colaboradoras: {companies.map((company) => company.data.name).join(", ")}.</p>

    <div
      aria-hidden="true"
      class="group relative mt-8 overflow-hidden [mask-image:linear-gradient(to_right,transparent,black_10%,black_90%,transparent)]"
    >
      <div class="flex w-max items-center gap-16 animate-marquee">
        {
          [...companies, ...companies].map((company) => (
            <Image
              src={company.data.logo}
              alt=""
              width={120}
              height={40}
              class="h-8 w-auto shrink-0 opacity-60 transition-opacity duration-200 hover:opacity-100"
            />
          ))
        }
      </div>
    </div>
  </section>

  <!-- Comunidad -->
  <section class="py-24">
    <Container>
      <div data-reveal class="relative grid grid-cols-1 items-center gap-12 overflow-hidden rounded-3xl bg-brand-600 p-10 text-white sm:p-16 lg:grid-cols-2">
        <div class="absolute inset-0 bg-grain"></div>
        <div class="glow-orb -bottom-20 -right-20 h-72 w-72 bg-brand-300/30"></div>

        <div class="relative">
          <Eyebrow class="text-white/80">Comunidad</Eyebrow>
          <h2 class="mt-4 font-display text-3xl font-semibold sm:text-4xl">No estudias solo</h2>
          <p class="mt-4 max-w-md text-base leading-relaxed text-white/85">
            Formas parte de una comunidad de alumnos y profesionales: networking, proyectos compartidos y, próximamente, eventos, mentorías y bolsa de empleo.
          </p>
        </div>
        <ul class="relative grid grid-cols-2 gap-4 text-sm font-medium">
          <li class="flex flex-col gap-2 rounded-2xl bg-white/10 p-5 transition-colors duration-200 hover:bg-white/15">
            <Icon name="users" class="h-5 w-5 text-white/80" />
            Networking entre alumnos
          </li>
          <li class="flex flex-col gap-2 rounded-2xl bg-white/10 p-5 transition-colors duration-200 hover:bg-white/15">
            <Icon name="briefcase" class="h-5 w-5 text-white/80" />
            Proyectos colaborativos
          </li>
          <li class="flex flex-col gap-2 rounded-2xl bg-white/10 p-5 transition-colors duration-200 hover:bg-white/15">
            <Icon name="calendar" class="h-5 w-5 text-white/80" />
            Eventos (próximamente)
          </li>
          <li class="flex flex-col gap-2 rounded-2xl bg-white/10 p-5 transition-colors duration-200 hover:bg-white/15">
            <Icon name="compass" class="h-5 w-5 text-white/80" />
            Bolsa de empleo (próximamente)
          </li>
        </ul>
      </div>
    </Container>
  </section>

</Layout>
